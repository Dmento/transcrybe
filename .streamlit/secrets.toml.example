# Streamlit secrets template.
#
# LOCAL: copy this file to ".streamlit/secrets.toml" (or just use a .env file).
# CLOUD: paste these two lines into the Streamlit Community Cloud app's
#        "Secrets" box (App settings -> Secrets).
#
# Never commit your real secrets.toml — it is git-ignored.

AZURE_SPEECH_KEY = "your_azure_speech_key_here"
AZURE_SPEECH_REGION = "westus2"

# OPTIONAL — a TURN relay, needed for real-time (WebRTC) live transcription on
# cloud hosting (Streamlit Cloud) and on phones / cellular networks (e.g.
# iPhone). Without it, real-time still works on desktop/same-network, and file
# upload + the Record tab always work. Use EITHER of the two options below.
#
# Option A (recommended): Cloudflare TURN. Create a TURN key at
# dash.cloudflare.com -> Realtime -> TURN, then paste its Key ID + API token.
# Credentials are minted fresh by the app, so nothing here expires.
# CLOUDFLARE_TURN_KEY_ID = "your_turn_key_id"
# CLOUDFLARE_TURN_API_TOKEN = "your_turn_api_token"
#
# Option B: a static TURN_CONFIG — a JSON list of ICE servers from any TURN
# provider (e.g. metered.ca).
# TURN_CONFIG = '[{"urls":["turn:HOST:443?transport=tcp","turn:HOST:80"],"username":"YOUR_USERNAME","credential":"YOUR_CREDENTIAL"}]'
